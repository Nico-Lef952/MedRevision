import React, { useEffect, useState } from 'react';
import { Link } from 'react-router-dom';
import { CalendarDays, FileText, PlayCircle } from 'lucide-react';
import { subjectsApi, annalesApi, formatApiError } from '../lib/api';

export default function AnnalesPage() {
  const [subjects, setSubjects] = useState([]);
  const [annales, setAnnales] = useState([]);
  const [selectedSubject, setSelectedSubject] = useState('');
  const [loading, setLoading] = useState(true);

  const loadData = async (subjectId = '') => {
    try {
      setLoading(true);

      const [subRes, annRes] = await Promise.all([
        subjectsApi.getAll(),
        annalesApi.getAll(subjectId ? { subject_id: subjectId } : {})
      ]);

      setSubjects(subRes.data || []);
      setAnnales(annRes.data || []);
    } catch (err) {
      alert(formatApiError(err));
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    loadData(selectedSubject);
  }, [selectedSubject]);

  const getSubjectName = (id) => {
    const s = subjects.find(x => String(x.id || x._id) === String(id));
    return s?.name || 'Matière inconnue';
  };

  return (
    <div className="space-y-6">
      <div className="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4">
        <div>
          <h1 className="text-3xl font-black text-[#0F172A]">Annales</h1>
          <p className="text-[#64748B]">Entraîne-toi sur les examens des années précédentes.</p>
        </div>

        <select
          value={selectedSubject}
          onChange={(e) => setSelectedSubject(e.target.value)}
          className="px-4 py-3 bg-white border border-[#E2E8F0] rounded-xl focus:outline-none focus:ring-2 focus:ring-[#4F46E5]"
        >
          <option value="">Toutes les matières</option>
          {subjects.map(s => (
            <option key={s.id || s._id} value={s.id || s._id}>
              {s.name}
            </option>
          ))}
        </select>
      </div>

      {loading ? (
        <div className="p-8 bg-white rounded-2xl border border-[#E2E8F0]">
          Chargement...
        </div>
      ) : annales.length === 0 ? (
        <div className="p-10 bg-white rounded-2xl border border-[#E2E8F0] text-center">
          <CalendarDays className="w-12 h-12 mx-auto mb-4 text-[#94A3B8]" />
          <h2 className="text-xl font-bold text-[#0F172A]">Aucune annale importée</h2>
          <p className="text-[#64748B] mt-2">Importe une annale pour commencer.</p>
        </div>
      ) : (
        <div className="grid grid-cols-1 xl:grid-cols-2 gap-4">
          {annales.map(a => (
            <div
              key={a.annale_id}
              className="p-5 bg-white border border-[#E2E8F0] rounded-2xl shadow-sm hover:shadow-md transition-all"
            >
              <div className="flex items-start gap-4">
                <div className="w-12 h-12 rounded-2xl bg-gradient-to-br from-[#4F46E5] to-[#EC4899] flex items-center justify-center shrink-0 shadow-lg">
                  <FileText className="w-6 h-6 text-white" />
                </div>

                <div className="flex-1 min-w-0">
                  <h2 className="text-lg font-bold text-[#0F172A] truncate">{a.title}</h2>
                  <p className="text-sm text-[#64748B]">
                    {getSubjectName(a.subject_id)} · {a.year} · {a.question_count} questions
                  </p>

                  <Link
                    to={`/quiz?auto_mode=annale&annale_id=${a.annale_id}&subject_id=${a.subject_id}&auto_count=${a.question_count}`}
                    className="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-xl bg-[#4F46E5] text-white font-semibold hover:bg-[#4338CA]"
                  >
                    <PlayCircle className="w-5 h-5" />
                    Lancer l’annale
                  </Link>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}
