def normalize_options(options):
    if not isinstance(options, list):
        return []

    clean = []
    for opt in options:
        if isinstance(opt, str):
            clean.append({"text": opt, "is_correct": False})
        elif isinstance(opt, dict):
            clean.append({
                "text": opt.get("text") or opt.get("label") or opt.get("answer") or "",
                "is_correct": bool(opt.get("is_correct", opt.get("correct", False)))
            })

    return [o for o in clean if o.get("text")]


def normalize_sub_questions(q):
    sub = (
        q.get("sub_questions")
        or q.get("subQuestions")
        or q.get("subquestions")
        or q.get("questions")
        or q.get("items")
        or []
    )

    if not isinstance(sub, list):
        return []

    clean = []
    for sq in sub:
        if not isinstance(sq, dict):
            continue

        sq_question = (
            sq.get("question")
            or sq.get("text")
            or sq.get("prompt")
            or sq.get("title")
            or ""
        )

        options = normalize_options(
            sq.get("options")
            or sq.get("choices")
            or sq.get("answers")
            or []
        )

        clean.append({
            "question": sq_question,
            "options": options,
            "answer": sq.get("answer", ""),
            "explanation": sq.get("explanation", sq.get("correction", "")),
            "type": sq.get("type", "qrm")
        })

    return [sq for sq in clean if sq.get("question")]


def validate_question(q, group):
    qtype = q.get("type", "")

    if group == "qroc":
        q["type"] = "qroc"
        if not q.get("answer"):
            q["answer"] = q.get("question", "")
        if not q.get("options"):
            q["options"] = [{"text": q.get("answer", ""), "is_correct": True}]

    elif group == "clinical":
        q["type"] = "cas_clinique"
        if not q.get("vignette"):
            print("Reject clinical: missing vignette")
            return None

    elif group == "dp":
        q["type"] = "dp"

        if not q.get("vignette"):
            q["vignette"] = q.get("case") or q.get("clinical_case") or q.get("scenario") or ""

        q["sub_questions"] = normalize_sub_questions(q)

        if not q.get("vignette"):
            print("Reject DP: missing vignette")
            return None

        if len(q.get("sub_questions", [])) < 2:
            print("Reject DP: not enough sub_questions")
            print("Raw keys:", list(q.keys()))
            return None

        q["options"] = normalize_options(q.get("options", []))
        q["answer"] = q.get("answer", "")
        q["explanation"] = q.get("explanation", "")

    else:
        if qtype not in ["qi", "qrm", "qcm", "vrai_faux"]:
            q["type"] = "qrm"

    if not q.get("question"):
        print("Reject question: missing question text")
        return None

    q["options"] = normalize_options(q.get("options", []))
    q["answer"] = q.get("answer", "")
    q["explanation"] = q.get("explanation", "")
    q["difficulty"] = q.get("difficulty", 2)
    q["rang"] = q.get("rang", "A")
    q["concepts"] = q.get("concepts", [])
    q["vignette"] = q.get("vignette", "")
    q["sub_questions"] = q.get("sub_questions", [])

    return q


async def insert_questions(user_id, course, subject_id, generated_questions, group):
    course_id = str(course["_id"])

    existing = await db.questions.find({
        "user_id": user_id,
        "course_id": course_id
    }).to_list(5000)

    existing_texts = {norm(q.get("question", "")) for q in existing}

    docs = []

    for raw in generated_questions:
        q = validate_question(raw, group)
        if not q:
            continue

        qn = norm(q.get("question", ""))
        if not qn or qn in existing_texts:
            continue

        existing_texts.add(qn)

        docs.append({
            "user_id": user_id,
            "course_id": course_id,
            "subject_id": subject_id,
            "type": q["type"],
            "question": q["question"],
            "options": q["options"],
            "answer": q["answer"],
            "explanation": q["explanation"],
            "difficulty": q["difficulty"],
            "concepts": q["concepts"],
            "rang": q["rang"],
            "vignette": q["vignette"],
            "sub_questions": q["sub_questions"],
            "created_at": datetime.now(timezone.utc).isoformat()
        })

    if docs:
        await db.questions.insert_many(docs)

    return len(docs)


async def build_candidates(user_id, args):
    courses = await db.courses.find({"user_id": user_id}).to_list(5000)
    candidates = []

    for course in courses:
        title = course.get("title", "")
        subject_id = course.get("subject_id", "")

        subject = await get_subject(subject_id)
        subject_name = subject.get("name", "Matiere inconnue") if subject else "Matiere inconnue"

        if args.only_subject and args.only_subject.lower() not in subject_name.lower():
            continue

        if args.course_contains and args.course_contains.lower() not in title.lower():
            continue

        stats = await get_course_stats(user_id, course)

        if stats["word_count"] < args.min_words:
            continue

        group = choose_generation_task(stats)
        if not group:
            continue

        missing_total = sum(stats["deficits"].values())
        priority = missing_total * 10 + stats["word_count"] / 150

        candidates.append({
            "course": course,
            "subject_id": subject_id,
            "subject_name": subject_name,
            "chapter": course.get("chapter", ""),
            "stats": stats,
            "group": group,
            "priority": priority,
        })

    priority_groups = [
        ["grog"],
        ["revêtement", "revetement", "dermato", "cutané", "cutane"],
        ["cardio", "cardiovasculaire"],
        ["respiratoire", "pneumo"],
        ["digestif"],
    ]

    def subject_rank(subject_name):
        name = (subject_name or "").lower()
        for idx, keys in enumerate(priority_groups):
            if any(k in name for k in keys):
                return idx
        return 999

    # Ordre principal = matière.
    # Dans une même matière, on garde la priorité du cours le plus incomplet.
    candidates.sort(key=lambda c: (subject_rank(c["subject_name"]), -c["priority"]))
    return candidates


async def generate_for_candidate(client, model, user_id, candidate):
    course = candidate["course"]
    subject_name = candidate["subject_name"]
    subject_id = candidate["subject_id"]
    chapter = candidate["chapter"]
    stats = candidate["stats"]
    group = candidate["group"]

    amount = min(batch_size_for_group(group), stats["deficits"][group])

    print("=" * 100)
    print(f"Course: {subject_name} -> {course.get('title', '')}")
    print(f"Section: {chapter}")
    print(f"Words: {stats['word_count']}")
    print(f"Current / target total: {stats['total_current']} / {stats['total_target']}")
    print(f"Counts: {stats['counts']}")
    print(f"Targets: {stats['targets']}")
    print(f"Generating group: {group} x {amount}")
    print("=" * 100)

    prompt = make_prompt(course, subject_name, chapter, stats, group, amount)

    response = client.models.generate_content(
        model=model,
        contents=prompt
    )

    data = extract_json(response.text or "")
    questions = data.get("questions", [])

    print(f"Generated raw items: {len(questions)}")
    print("Generated types:", [q.get("type") for q in questions if isinstance(q, dict)])

    inserted = await insert_questions(user_id, course, subject_id, questions, group)

    if inserted == 0:
        Path("debug_last_gemini_response.json").write_text(
            json.dumps(data, ensure_ascii=False, indent=2),
            encoding="utf-8"
        )
        print("Debug saved: debug_last_gemini_response.json")

    print(f"Strategy: {data.get('coverage_strategy', '')}")
    print(f"Inserted: {inserted}")

    return inserted


async def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--model", default="")
    parser.add_argument("--loop", action="store_true")
    parser.add_argument("--limit-calls", type=int, default=10)
    parser.add_argument("--delay", type=int, default=60)
    parser.add_argument("--quota-sleep", type=int, default=3600)
    parser.add_argument("--overload-sleep", type=int, default=900)
    parser.add_argument("--min-words", type=int, default=80)
    parser.add_argument("--only-subject", default="")
    parser.add_argument("--course-contains", default="")

    args = parser.parse_args()

    load_env()

    api_key = os.environ.get("GEMINI_API_KEY") or os.environ.get("GOOGLE_API_KEY")
    if not api_key:
        raise RuntimeError("No GEMINI_API_KEY or GOOGLE_API_KEY in .env")

    model = args.model or os.environ.get("GEMINI_MODEL", "gemini-3.1-flash-lite")
    client = genai.Client(api_key=api_key)

    user = await get_user()
    user_id = str(user["_id"])

    calls = 0

    print("")
    print("SMART BANK GENERATOR")
    print(f"Model: {model}")
    print("Goal: balanced question bank per course and per type.")
    print("Ctrl+C to stop.")
    print("")

    while True:
        try:
            if calls >= args.limit_calls:
                print("Limit calls reached.")
                return

            candidates = await build_candidates(user_id, args)

            if not candidates:
                print("All matching courses have reached their targets.")
                if args.loop:
                    sleep_msg(1800, "checking again later")
                    continue
                return

            print("")
            print(f"Candidates: {len(candidates)}")
            print("Top 5:")
            for c in candidates[:5]:
                st = c["stats"]
                print(
                    f"- {c['subject_name']} -> {c['course'].get('title', '')} "
                    f"| group {c['group']} | total {st['total_current']}/{st['total_target']}"
                )
            print("")

            inserted = await generate_for_candidate(client, model, user_id, candidates[0])
            calls += 1

            if inserted == 0:
                sleep_msg(180, "nothing inserted, possible duplicates")
            else:
                sleep_msg(args.delay, "normal pause")

            if not args.loop and calls >= args.limit_calls:
                print("Done.")
                return

        except KeyboardInterrupt:
            print("")
            print("Manual stop.")
            return

        except Exception as err:
            msg = str(err).lower()
            print("")
            print("Error:")
            print(err)

            if "429" in msg or "quota" in msg or "resource_exhausted" in msg:
                sleep_msg(args.quota_sleep, "quota reached")
            elif "503" in msg or "unavailable" in msg or "overload" in msg or "high demand" in msg:
                sleep_msg(args.overload_sleep + random.randint(0, 300), "Gemini overloaded")
            else:
                sleep_msg(300, "unknown error")


if __name__ == "__main__":
    asyncio.run(main())
