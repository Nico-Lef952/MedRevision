import React, { useState, useEffect, useRef } from 'react';
import { useSearchParams, Link } from 'react-router-dom';
import { quizApi, subjectsApi, coursesApi, questionsApi, formatApiError } from '../lib/api';
import {
  Play,
  CheckCircle,
  XCircle,
  ArrowRight,
  RotateCcw,
  Trophy,
  Clock,
  Target,
  Bookmark,
  BookmarkCheck,
  AlarmClockOff,
  BookOpen,
  Sparkles,
  Brain,
  AlertCircle,
  Star
} from 'lucide-react';

const MODE_META = {
  subject: { label: 'Par matière', icon: BookOpen },
  course: { label: 'Par cours', icon: BookOpen },
  annale: { label: 'Annale', icon: BookOpen },
  transversal: { label: 'Transversal', icon: Target },
  errors: { label: 'Mes erreurs', icon: AlertCircle },
  due: { label: 'À ancrer', icon: Brain },
  bookmarked: { label: 'Mes favoris', icon: Star },
  new: { label: 'Nouvelles', icon: Sparkles }
};

const TYPE_LABEL = {
  qi: 'QI',
  qrm: 'QRM',
  qroc: 'QROC',
  dp: 'DP',
  qcm: 'QCM',
  vrai_faux: 'V/F',
  flashcard: 'Flashcard',
  cas_clinique: 'Cas clinique'
};

export default function QuizPage() {
  const [searchParams] = useSearchParams();
  const [subjects, setSubjects] = useState([]);
  const [courses, setCourses] = useState([]);
  const [loading, setLoading] = useState(true);

  // Quiz config
  const [mode, setMode] = useState(searchParams.get('auto_mode') || 'subject');
  const [selectedSubject, setSelectedSubject] = useState(searchParams.get('subject_id') || '');
  const [selectedCourse, setSelectedCourse] = useState(searchParams.get('course_id') || '');
  const [selectedAnnale] = useState(searchParams.get('annale_id') || '');
  const [questionCount, setQuestionCount] = useState(parseInt(searchParams.get('auto_count')) || 10);
  const [questionTypes, setQuestionTypes] = useState(['qi', 'qrm', 'qroc', 'dp', 'qcm', 'vrai_faux', 'cas_clinique']);

  // Quiz state
  const [session, setSession] = useState(null);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [selectedOptions, setSelectedOptions] = useState([]);
  const [qrocText, setQrocText] = useState('');
  const [dpStep, setDpStep] = useState(0);
  const [dpAnswers, setDpAnswers] = useState([]);
  const [answered, setAnswered] = useState(false);
  const [result, setResult] = useState(null);
  const [finalResult, setFinalResult] = useState(null);
  const [startTime, setStartTime] = useState(null);
  const [answering, setAnswering] = useState(false);
  const [bookmarked, setBookmarked] = useState({});
  const [snoozeMenu, setSnoozeMenu] = useState(false);
  const [courseExcerpt, setCourseExcerpt] = useState(null);
  const [courseExcerptOpen, setCourseExcerptOpen] = useState(false);
  const [courseExcerptLoading, setCourseExcerptLoading] = useState(false);
  const autoStartedRef = useRef(false);


  // AUTO_START_ANNALE_PATCH
  useEffect(() => {
    if (autoStartedRef.current) return;

    const isAutoAnnale = searchParams.get('auto_mode') === 'annale';
    const annaleId = searchParams.get('annale_id');

    if (isAutoAnnale && annaleId && !session && !loading) {
      autoStartedRef.current = true;
      startQuiz();
    }
  }, [loading, session]);

  useEffect(() => {
    const fetchData = async () => {
      try {
        const [subRes, courseRes] = await Promise.all([
          subjectsApi.getAll(),
          coursesApi.getAll({})
        ]);
        setSubjects(subRes.data);
        setCourses(courseRes.data);

        if (searchParams.get('course_id')) setMode('course');
      } catch (err) {
        console.error(err);
        alert(formatApiError(err));
      } finally {
        setLoading(false);
      }
    };
    fetchData();
  }, []);

  // Auto-start quiz from query params (after navigation from Ancrage page)
  useEffect(() => {
    const autoMode = searchParams.get('auto_mode');
    if (autoMode && !loading && !session && !autoStartedRef.current) {
      autoStartedRef.current = true;
      startQuiz(autoMode, parseInt(searchParams.get('auto_count')) || 10);
    }
  }, [loading]);

  const startQuiz = async (overrideMode, overrideCount) => {
    try {
      const effectiveMode = overrideMode || mode;
      const effectiveCount = overrideCount || questionCount;

      const res = await quizApi.start({
        mode: effectiveMode,
        subject_id: effectiveMode === 'subject' ? selectedSubject : undefined,
        course_id: effectiveMode === 'course' ? selectedCourse : undefined,
        annale_id: effectiveMode === 'annale' ? selectedAnnale : undefined,
        question_count: effectiveCount,
        question_types: questionTypes.length > 0 ? questionTypes : undefined
      });
      setSession(res.data);
      setCurrentIndex(0);
      setSelectedOptions([]);
      setQrocText('');
      setDpStep(0);
      setDpAnswers([]);
      setAnswered(false);
      setResult(null);
      setCourseExcerpt(null);
      setCourseExcerptOpen(false);
      setCourseExcerptLoading(false);
      setFinalResult(null);
      setStartTime(Date.now());
      setBookmarked({});
    } catch (err) {
      alert(formatApiError(err));
    }
  };

  const submitAnswer = async () => {
    if (answering) return;
    const question = session.questions[currentIndex];

    if (question.type === 'dp') {
      const subQuestions = question.sub_questions || [];

      if (!subQuestions.length) {
        alert("Ce DP ne contient pas de sous-questions exploitables.");
        return;
      }

      const newDpAnswers = [...dpAnswers];
      newDpAnswers[dpStep] = selectedOptions;
      setDpAnswers(newDpAnswers);

      if (dpStep < subQuestions.length - 1) {
        setDpStep(dpStep + 1);
        setSelectedOptions([]);
        setQrocText('');
        return;
      }

      setAnswering(true);
      try {
        const timeSpent = Math.round((Date.now() - startTime) / 1000);
        const res = await quizApi.answer(session.session_id, {
          question_id: question.id,
          selected_options: [],
          dp_answers: newDpAnswers,
          time_spent: timeSpent
        });
        setResult(res.data);
        setAnswered(true);
      } catch (err) {
        alert(formatApiError(err));
      } finally {
        setAnswering(false);
      }
      return;
    }

    // For QROC, compare text loosely (case insensitive includes)
    if (question.type === 'qroc' && qrocText.trim()) {
      const expected = (question.options?.[0]?.text || '').toLowerCase().trim();
      const given = qrocText.toLowerCase().trim();
      const isCorrect = given.includes(expected) || expected.includes(given);

      setAnswering(true);
      try {
        const timeSpent = Math.round((Date.now() - startTime) / 1000);
        // Use selected_options [0] if matches expected, else []
        await quizApi.answer(session.session_id, {
          question_id: question.id,
          selected_options: isCorrect ? [0] : [],
          time_spent: timeSpent
        });
        setResult({
          is_correct: isCorrect,
          correct_options: [0],
          explanation: question.explanation || `Réponse attendue : ${expected}`,
          answer: expected
        });
        setAnswered(true);
      } catch (err) {
        alert(formatApiError(err));
      } finally {
        setAnswering(false);
      }
      return;
    }

    setAnswering(true);
    try {
      const timeSpent = Math.round((Date.now() - startTime) / 1000);
      const res = await quizApi.answer(session.session_id, {
        question_id: question.id,
        selected_options: selectedOptions,
        time_spent: timeSpent
      });
      setResult(res.data);
      setAnswered(true);
    } catch (err) {
      alert(formatApiError(err));
    } finally {
      setAnswering(false);
    }
  };

  const nextQuestion = async () => {
    if (currentIndex < session.questions.length - 1) {
      setCurrentIndex(currentIndex + 1);
      setSelectedOptions([]);
      setQrocText('');
      setDpStep(0);
      setDpAnswers([]);
      setAnswered(false);
      setResult(null);
      setCourseExcerpt(null);
      setCourseExcerptOpen(false);
      setCourseExcerptLoading(false);
      setStartTime(Date.now());
      setSnoozeMenu(false);
    } else {
      try {
        const res = await quizApi.complete(session.session_id);
        setFinalResult(res.data);
      } catch (err) {
        console.error(err);
      }
    }
  };

  const resetQuiz = () => {
    setSession(null);
    setCurrentIndex(0);
    setSelectedOptions([]);
    setQrocText('');
    setDpStep(0);
    setDpAnswers([]);
    setAnswered(false);
    setResult(null);
    setFinalResult(null);
    autoStartedRef.current = false;
  };

  const normalizeSearchText = (text) =>
    (text || '')
      .toString()
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

  const escapeHtml = (text) =>
    (text || '')
      .toString()
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');

  const escapeRegex = (text) =>
    (text || '').toString().replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

  const getMeaningfulWords = (text) => {
    const stopwords = new Set([
      'dans', 'avec', 'pour', 'chez', 'cette', 'question', 'quelle', 'quel',
      'quels', 'quelles', 'sont', 'est', 'une', 'des', 'les', 'aux', 'par',
      'sur', 'plus', 'moins', 'entre', 'comme', 'cours', 'patient', 'patients',
      'reponse', 'bonne', 'mauvaise', 'vrai', 'faux', 'donc', 'ainsi',
      'être', 'etre', 'fait', 'peut', 'sous', 'vers', 'leur', 'leurs',
      'cela', 'ceci', 'dont', 'sans', 'avec', 'apres', 'avant'
    ]);

    return (text || '')
      .toString()
      .replace(/[^\wÀ-ÿ'-]+/g, ' ')
      .split(/\s+/)
      .map(w => w.trim())
      .filter(w => w.length >= 4)
      .filter(w => !stopwords.has(normalizeSearchText(w)));
  };

  const buildCorrectionSearchData = (question, result) => {
    const correctOptions = (question.options || [])
      .filter(o => o?.is_correct)
      .map(o => o.text || '');

    const correctionText = [
      result?.explanation,
      result?.answer,
      question.answer,
      ...correctOptions,
      ...(question.concepts || [])
    ].filter(Boolean).join(' ');

    const questionText = [
      question.question,
      question.vignette
    ].filter(Boolean).join(' ');

    const priorityWords = [...new Set(getMeaningfulWords(correctionText))];
    const secondaryWords = [...new Set(getMeaningfulWords(questionText))];

    const importantPhrases = [
      result?.answer,
      question.answer,
      ...correctOptions,
      ...(question.concepts || [])
    ]
      .filter(Boolean)
      .map(x => x.toString().trim())
      .filter(x => x.length >= 4);

    return {
      correctionText,
      questionText,
      priorityWords,
      secondaryWords,
      importantPhrases
    };
  };

  const splitIntoSentences = (text) => {
    const clean = (text || '').replace(/\r\n/g, '\n');

    // On garde aussi les lignes Markdown comme unités, car tes cours sont structurés.
    const lineUnits = clean
      .split(/\n+/)
      .map(x => x.trim())
      .filter(x => x.length > 20);

    const sentenceUnits = clean
      .split(/(?<=[.!?])\s+/)
      .map(x => x.trim())
      .filter(x => x.length > 30);

    return [...lineUnits, ...sentenceUnits];
  };

  const scoreTextForCorrection = (text, searchData) => {
    const normalized = normalizeSearchText(text);
    let score = 0;

    // Les mots de la correction comptent beaucoup plus que les mots de l'énoncé.
    for (const word of searchData.priorityWords) {
      const needle = normalizeSearchText(word);
      if (!needle) continue;
      const matches = normalized.match(new RegExp(escapeRegex(needle), 'g'));
      if (matches) score += matches.length * Math.min(needle.length, 14) * 3;
    }

    // Les mots de la question aident seulement en appoint.
    for (const word of searchData.secondaryWords.slice(0, 12)) {
      const needle = normalizeSearchText(word);
      if (!needle) continue;
      const matches = normalized.match(new RegExp(escapeRegex(needle), 'g'));
      if (matches) score += matches.length * Math.min(needle.length, 10);
    }

    // Les phrases importantes donnent un gros bonus si elles apparaissent.
    for (const phrase of searchData.importantPhrases) {
      const needle = normalizeSearchText(phrase);
      if (needle.length >= 5 && normalized.includes(needle)) {
        score += 120;
      }
    }

    return score;
  };

  const highlightExcerpt = (text, searchData, bestSentence = '') => {
    let html = escapeHtml(text);

    const phrases = searchData.importantPhrases
      .filter(k => k.length >= 4)
      .sort((a, b) => b.length - a.length)
      .slice(0, 8);

    const words = searchData.priorityWords
      .filter(k => k.length >= 4)
      .sort((a, b) => b.length - a.length)
      .slice(0, 18);

    // Surlignage fort des phrases/réponses exactes.
    for (const phrase of phrases) {
      const re = new RegExp(`(${escapeRegex(phrase)})`, 'gi');
      html = html.replace(
        re,
        '<mark class="bg-orange-200 text-[#1E293B] px-1.5 py-0.5 rounded font-semibold">$1</mark>'
      );
    }

    // Surlignage plus léger des mots importants de la correction.
    for (const word of words) {
      const re = new RegExp(`(${escapeRegex(word)})`, 'gi');
      html = html.replace(
        re,
        '<mark class="bg-yellow-200 text-[#1E293B] px-1 rounded">$1</mark>'
      );
    }

    // Encadre la phrase la plus probable si elle est retrouvable.
    if (bestSentence && bestSentence.length > 20) {
      const safeSentence = escapeHtml(bestSentence);
      const sentenceRegex = new RegExp(escapeRegex(safeSentence), 'i');
      html = html.replace(
        sentenceRegex,
        `<span class="block my-2 p-3 rounded-xl bg-[#EEF2FF] border-l-4 border-[#4F46E5] font-medium">${safeSentence}</span>`
      );
    }

    return html.replace(/\n/g, '<br />');
  };

  const findBestCourseExcerpt = (content, question, result) => {
    if (!content) {
      return {
        title: 'Cours introuvable',
        html: 'Impossible de récupérer le contenu du cours.'
      };
    }

    const searchData = buildCorrectionSearchData(question, result);
    const sentences = splitIntoSentences(content);

    let bestSentence = '';
    let bestSentenceScore = -1;

    for (const sentence of sentences) {
      const score = scoreTextForCorrection(sentence, searchData);
      if (score > bestSentenceScore) {
        bestSentenceScore = score;
        bestSentence = sentence;
      }
    }

    const fullText = content.replace(/\r\n/g, '\n');
    const pos = bestSentence
      ? normalizeSearchText(fullText).indexOf(normalizeSearchText(bestSentence).slice(0, 80))
      : -1;

    let excerpt = '';

    if (pos >= 0) {
      const start = Math.max(0, pos - 450);
      const end = Math.min(fullText.length, pos + bestSentence.length + 650);
      excerpt = `${start > 0 ? '...' : ''}${fullText.slice(start, end)}${end < fullText.length ? '...' : ''}`;
    } else {
      // Fallback : on prend le meilleur paragraphe.
      const chunks = splitCourseContent(content);
      let bestChunk = chunks[0] || content.slice(0, 1000);
      let bestScore = -1;

      for (const chunk of chunks) {
        const score = scoreTextForCorrection(chunk, searchData);
        if (score > bestScore) {
          bestScore = score;
          bestChunk = chunk;
        }
      }

      excerpt = bestChunk.length > 1400 ? bestChunk.slice(0, 1400) + '...' : bestChunk;
    }

    return {
      title: bestSentenceScore > 0
        ? 'Passage le plus proche de la correction'
        : 'Extrait probable du cours',
      html: highlightExcerpt(excerpt, searchData, bestSentence)
    };
  };



  const getCourseContentFromObject = (course) =>
    course?.content ||
    course?.text ||
    course?.markdown ||
    course?.body ||
    course?.raw_content ||
    '';

  const findCourseInList = (list, courseId) =>
    (list || []).find(course =>
      String(course.id || course._id) === String(courseId)
    );

  const handleShowCourseExcerpt = async () => {
    const question = session?.questions?.[currentIndex];
    if (!question?.course_id) return;

    if (courseExcerptOpen && courseExcerpt) {
      setCourseExcerptOpen(false);
      return;
    }

    setCourseExcerptLoading(true);

    try {
      let course = findCourseInList(courses, question.course_id);
      let content = getCourseContentFromObject(course);

      // Fallback : on recharge la liste des cours si le contenu n'est pas dans le state.
      if (!content) {
        try {
          const allRes = await coursesApi.getAll({});
          const list = Array.isArray(allRes.data)
            ? allRes.data
            : (allRes.data?.courses || []);

          course = findCourseInList(list, question.course_id) || course;
          content = getCourseContentFromObject(course);
        } catch (err) {
          console.warn('Impossible de recharger la liste des cours', err);
        }
      }

      // Fallback optionnel : getById si la route existe.
      // Si elle n'existe pas, on ignore l'erreur pour éviter l'alerte Not Found.
      if (!content && coursesApi.getById) {
        try {
          const res = await coursesApi.getById(question.course_id);
          course = res.data?.course || res.data;
          content = getCourseContentFromObject(course);
          console.log('Cours récupéré via getById', course);
        } catch (err) {
          console.warn('Route getById indisponible', err);
        }
      }

      // Fallback très utile : récupérer le HTML du cours puis le convertir en texte.
      if (!content && coursesApi.getFileHtml) {
        try {
          const htmlRes = await coursesApi.getFileHtml(question.course_id);
          const html = htmlRes.data || '';

          const tmp = document.createElement('div');
          tmp.innerHTML = html;
          content = tmp.textContent || tmp.innerText || '';

          console.log('Cours récupéré via getFileHtml, longueur texte :', content.length);
        } catch (err) {
          console.warn('Route getFileHtml indisponible', err);
        }
      }

      if (!content) {
        setCourseExcerpt({
          title: 'Passage non disponible',
          html: 'Le cours est bien lié à la question, mais son contenu complet n’est pas encore récupérable par le quiz.'
        });
        setCourseExcerptOpen(true);
        return;
      }

      const excerpt = findBestCourseExcerpt(content, question, result);
      setCourseExcerpt(excerpt);
      setCourseExcerptOpen(true);
    } catch (err) {
      console.error('Erreur passage du cours:', err);

      const message =
        err?.response?.data?.detail ||
        err?.response?.data?.message ||
        err?.message ||
        formatApiError(err) ||
        'Erreur inconnue';

      setCourseExcerpt({
        title: 'Erreur pendant la recherche du passage',
        html: `Erreur : ${escapeHtml(message)}`
      });
      setCourseExcerptOpen(true);
    } finally {
      setCourseExcerptLoading(false);
    }
  };

  const toggleOption = (index) => {
    if (answered) return;
    const question = session.questions[currentIndex];
    const effectiveQuestion = question.type === 'dp'
      ? (question.sub_questions?.[dpStep] || question)
      : question;

    // Single-select: QI and Vrai/Faux. All others (QRM, QCM, cas_clinique) allow multi-select
    if (effectiveQuestion.type === 'qi' || effectiveQuestion.type === 'vrai_faux') {
      setSelectedOptions([index]);
    } else {
      setSelectedOptions(prev =>
        prev.includes(index) ? prev.filter(i => i !== index) : [...prev, index]
      );
    }
  };

  const toggleQuestionType = (type) => {
    setQuestionTypes(prev =>
      prev.includes(type) ? prev.filter(t => t !== type) : [...prev, type]
    );
  };

  const handleBookmark = async () => {
    const q = session.questions[currentIndex];
    try {
      const res = await questionsApi.bookmark(q.id);
      setBookmarked(prev => ({ ...prev, [q.id]: res.data.bookmarked }));
    } catch (err) {
      console.error(err);
    }
  };

  const handleSnooze = async (days) => {
    const q = session.questions[currentIndex];
    try {
      await questionsApi.snooze(q.id, days);
      setSnoozeMenu(false);
      // Auto-skip to next
      setTimeout(nextQuestion, 300);
    } catch (err) {
      alert(formatApiError(err));
    }
  };

  if (loading) {
    return (
      <div className="space-y-6">
        <div className="h-10 w-64 skeleton rounded-lg" />
        <div className="h-96 skeleton rounded-2xl" />
      </div>
    );
  }

  // ============= FINAL RESULTS =============
  if (finalResult) {
    const percentage = finalResult.percentage;
    const isGood = percentage >= 70;
    return (
      <div className="max-w-2xl mx-auto" data-testid="quiz-results">
        <div className="bg-white rounded-2xl border border-[#E2E8F0] p-8 text-center shadow-lg">
          <div className={`w-24 h-24 mx-auto rounded-full flex items-center justify-center mb-6 ${isGood ? 'bg-gradient-to-br from-[#22C55E] to-[#16A34A]' : 'bg-gradient-to-br from-[#F59E0B] to-[#EF4444]'}`}>
            <Trophy className="w-12 h-12 text-white" />
          </div>
          <h2 className="text-3xl font-bold text-[#1E293B] mb-2" style={{ fontFamily: 'Outfit, sans-serif' }}>
            Quiz terminé !
          </h2>
          <div className={`text-7xl font-black my-6 ${isGood ? 'text-[#22C55E]' : 'text-[#EF4444]'}`}>
            {percentage}%
          </div>
          <p className="text-[#64748B] mb-6 text-lg">
            {finalResult.score} / {finalResult.total} bonnes réponses
          </p>
          <div className="flex gap-3 justify-center flex-wrap">
            <button
              onClick={resetQuiz}
              className="flex items-center gap-2 px-6 py-3 bg-[#1E293B] text-white rounded-xl font-semibold hover:bg-[#0F172A] transition-colors"
              data-testid="new-quiz-btn"
            >
              <RotateCcw className="w-5 h-5" />
              Nouveau quiz
            </button>
            <Link
              to="/ancrage"
              className="flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[#4F46E5] to-[#7C3AED] text-white rounded-xl font-semibold hover:opacity-90"
            >
              <Brain className="w-5 h-5" />
              Voir mon ancrage
            </Link>
          </div>
        </div>
      </div>
    );
  }

  // ============= QUIZ IN PROGRESS =============
  if (session) {
    const question = session.questions[currentIndex];
    const isDp = question.type === 'dp';
    const dpSubQuestions = question.sub_questions || [];
    const displayQuestion = isDp ? (dpSubQuestions[dpStep] || question) : question;
    const progress = ((currentIndex + 1) / session.total) * 100;
    const isQroc = displayQuestion.type === 'qroc';
    const isBookmarked = bookmarked[question.id];
    const correctOptions = result?.correct_options || [];

    if (answered && result?.is_dp) {
      return (
        <div className="max-w-3xl mx-auto space-y-6" data-testid="dp-final-correction">
          <div className="flex items-center justify-between gap-4 flex-wrap">
            <div className="flex items-center gap-3">
              <span className="text-sm text-[#64748B]">Question {currentIndex + 1} / {session.total}</span>
              <span className="badge badge-primary uppercase">DP</span>
              {question.rang && <span className={`badge ${question.rang === 'A' ? 'badge-success' : 'badge-warning'}`}>Rang {question.rang}</span>}
            </div>
          </div>

          <div className="w-full h-2 bg-[#E2E8F0] rounded-full overflow-hidden">
            <div
              className="h-full bg-gradient-to-r from-[#4F46E5] to-[#7C3AED] transition-all duration-300"
              style={{ width: `${progress}%` }}
            />
          </div>

          <div className={`bg-white rounded-2xl border p-6 shadow-sm border-l-4 ${
            result.is_correct ? 'border-l-[#22C55E]' : 'border-l-[#EF4444]'
          }`}>
            <div className="flex items-center gap-2 mb-4">
              {result.is_correct ? (
                <CheckCircle className="w-5 h-5 text-[#22C55E]" />
              ) : (
                <XCircle className="w-5 h-5 text-[#EF4444]" />
              )}
              <h3 className="text-xl font-bold text-[#1E293B]">Correction du DP</h3>
            </div>

            <p className="text-sm font-semibold text-[#334155] mb-5">
              Score du DP : {result.dp_score} / {result.dp_total}
            </p>

            <div className="space-y-4">
              {result.dp_results?.map((r, i) => (
                <div key={i} className="p-4 bg-[#F8FAFC] rounded-xl border border-[#E2E8F0]">
                  <p className="font-semibold text-sm text-[#1E293B] mb-2">
                    Sous-question {i + 1} : {r.is_correct ? '✅ Correct' : '❌ Incorrect'}
                  </p>

                  <p className="text-sm text-[#334155] mb-3">{r.question}</p>

                  {(dpSubQuestions[i]?.options || []).length > 0 && (
                    <div className="space-y-2 mb-3">
                      {(dpSubQuestions[i]?.options || []).map((opt, optIdx) => {
                        const isSelected = r.selected_options?.includes(optIdx);
                        const isCorrect = r.correct_options?.includes(optIdx);

                        let optClass = 'border-[#E2E8F0] bg-white';
                        if (isCorrect) optClass = 'border-[#22C55E] bg-[#F0FDF4]';
                        if (isSelected && !isCorrect) optClass = 'border-[#EF4444] bg-[#FEF2F2]';

                        return (
                          <div key={optIdx} className={`p-3 rounded-lg border text-sm ${optClass}`}>
                            <div className="flex items-start gap-3">
                              <span className="w-7 h-7 rounded-full bg-[#F1F5F9] text-[#64748B] flex items-center justify-center font-bold shrink-0">
                                {String.fromCharCode(65 + optIdx)}
                              </span>
                              <div className="flex-1">
                                <p className="text-[#1E293B]">{opt.text}</p>
                                <div className="flex gap-2 mt-1 flex-wrap">
                                  {isSelected && (
                                    <span className="text-xs font-semibold text-[#4F46E5]">
                                      Votre réponse
                                    </span>
                                  )}
                                  {isCorrect && (
                                    <span className="text-xs font-semibold text-[#16A34A]">
                                      Bonne réponse
                                    </span>
                                  )}
                                </div>
                              </div>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  )}

                  {r.explanation && (
                    <p className="text-sm text-[#64748B] whitespace-pre-line">{r.explanation}</p>
                  )}
                </div>
              ))}
            </div>

            <div className="flex justify-end mt-6">
              <button
                onClick={nextQuestion}
                className="flex items-center gap-2 bg-gradient-to-r from-[#4F46E5] to-[#7C3AED] text-white px-6 py-3 rounded-xl font-medium hover:opacity-90 transition-opacity"
                data-testid="next-question-btn"
              >
                {currentIndex < session.questions.length - 1 ? 'Suivant' : 'Terminer'}
                <ArrowRight className="w-5 h-5" />
              </button>
            </div>
          </div>
        </div>
      );
    }


    return (
      <div className="max-w-3xl mx-auto space-y-6" data-testid="quiz-in-progress">
        {/* Progress + actions */}
        <div className="flex items-center justify-between gap-4 flex-wrap">
          <div className="flex items-center gap-3">
            <span className="text-sm text-[#64748B]">Question {currentIndex + 1} / {session.total}</span>
            <span className="badge badge-primary uppercase">{TYPE_LABEL[question.type] || question.type}</span>
            {isDp && <span className="badge badge-warning">Sous-question {dpStep + 1} / {dpSubQuestions.length}</span>}
            {question.rang && <span className={`badge ${question.rang === 'A' ? 'badge-success' : 'badge-warning'}`}>Rang {question.rang}</span>}
          </div>
          <div className="flex items-center gap-2">
            <button
              onClick={handleBookmark}
              className={`p-2 rounded-xl transition-colors ${isBookmarked ? 'bg-[#FEF3C7] text-[#F59E0B]' : 'text-[#64748B] hover:bg-[#F1F5F9]'}`}
              title="Marquer comme favori"
              data-testid="bookmark-btn"
            >
              {isBookmarked ? <BookmarkCheck className="w-5 h-5" /> : <Bookmark className="w-5 h-5" />}
            </button>
            <div className="relative">
              <button
                onClick={() => setSnoozeMenu(!snoozeMenu)}
                className="flex items-center gap-1 px-3 py-2 text-[#64748B] hover:bg-[#F1F5F9] rounded-xl text-sm font-medium"
                data-testid="snooze-btn"
              >
                <AlarmClockOff className="w-4 h-4" />
                Reporter
              </button>
              {snoozeMenu && (
                <div className="absolute right-0 top-full mt-2 bg-white border border-[#E2E8F0] rounded-xl shadow-lg z-10 overflow-hidden">
                  <button onClick={() => handleSnooze(1)} className="block w-full text-left px-4 py-2 hover:bg-[#F1F5F9] text-sm" data-testid="snooze-1d">1 jour</button>
                  <button onClick={() => handleSnooze(7)} className="block w-full text-left px-4 py-2 hover:bg-[#F1F5F9] text-sm" data-testid="snooze-7d">1 semaine</button>
                  <button onClick={() => handleSnooze(30)} className="block w-full text-left px-4 py-2 hover:bg-[#F1F5F9] text-sm" data-testid="snooze-30d">1 mois</button>
                </div>
              )}
            </div>
          </div>
        </div>

        <div className="w-full h-2 bg-[#E2E8F0] rounded-full overflow-hidden">
          <div
            className="h-full bg-gradient-to-r from-[#4F46E5] to-[#7C3AED] transition-all duration-300"
            style={{ width: `${progress}%` }}
          />
        </div>

        {/* Question Card */}
        <div className="bg-white rounded-2xl border border-[#E2E8F0] p-6 shadow-sm">
          {question.vignette && (
            <div className="mb-5 p-4 bg-[#F0F4FF] rounded-xl border-l-4 border-[#4F46E5]">
              <p className="text-xs uppercase font-bold text-[#4F46E5] mb-2">Vignette clinique</p>
              <p className="text-sm text-[#334155] whitespace-pre-line">{question.vignette}</p>
            </div>
          )}
              {question.image_urls && question.image_urls.length > 0 && (
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                  {question.image_urls.map((url, idx) => {
                    const src = url.startsWith('http') ? url : `http://localhost:8000${url}`;

                    return (
                      <div key={idx} className="bg-white border border-[#E2E8F0] rounded-2xl p-3 shadow-sm">
                        <img
                          src={src}
                          alt={`Iconographie ${idx + 1}`}
                          className="w-full max-h-[520px] object-contain rounded-xl"
                        />
                      </div>
                    );
                  })}
                </div>
              )}


          <h3 className="text-xl font-semibold text-[#1E293B] mb-6" data-testid="question-text">
            {displayQuestion.question}
          </h3>

          {isQroc ? (
            <div>
              <textarea
                value={qrocText}
                onChange={(e) => !answered && setQrocText(e.target.value)}
                disabled={answered}
                placeholder="Tapez votre réponse..."
                rows={3}
                className={`w-full px-4 py-3 border-2 rounded-xl outline-none ${
                  answered
                    ? result?.is_correct
                      ? 'border-[#22C55E] bg-[#F0FDF4]'
                      : 'border-[#EF4444] bg-[#FEF2F2]'
                    : 'border-[#E2E8F0] focus:border-[#4F46E5]'
                }`}
                data-testid="qroc-input"
              />
              {answered && (
                <p className="mt-2 text-sm">
                  <span className="text-[#64748B]">Réponse attendue : </span>
                  <span className="font-semibold text-[#22C55E]">{result?.answer}</span>
                </p>
              )}
            </div>
          ) : (
            <div className="space-y-3">
              {displayQuestion.options?.map((opt, idx) => {
                let optClass = 'border-[#E2E8F0] hover:border-[#94A3B8] hover:bg-[#F8FAFC]';
                if (answered && result) {
                  if (correctOptions.includes(idx)) {
                    optClass = 'border-[#22C55E] bg-[#F0FDF4]';
                  } else if (selectedOptions.includes(idx)) {
                    optClass = 'border-[#EF4444] bg-[#FEF2F2]';
                  } else {
                    optClass = 'border-[#E2E8F0]';
                  }
                } else if (selectedOptions.includes(idx)) {
                  optClass = 'border-[#4F46E5] bg-[#EFF6FF]';
                }

                return (
                  <button
                    key={idx}
                    onClick={() => toggleOption(idx)}
                    disabled={answered}
                    className={`w-full p-4 text-left border-2 rounded-xl flex items-center gap-4 transition-all ${optClass} ${answered ? 'cursor-default' : 'cursor-pointer'}`}
                    data-testid={`option-${idx}`}
                  >
                    <span className={`w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold shrink-0 ${
                      answered && correctOptions.includes(idx) ? 'bg-[#22C55E] text-white' :
                      answered && selectedOptions.includes(idx) ? 'bg-[#EF4444] text-white' :
                      selectedOptions.includes(idx) ? 'bg-[#4F46E5] text-white' :
                      'bg-[#F1F5F9] text-[#64748B]'
                    }`}>
                      {String.fromCharCode(65 + idx)}
                    </span>
                    <span className="flex-1 text-[#1E293B]">{opt.text}</span>
                    {answered && correctOptions.includes(idx) && <CheckCircle className="w-5 h-5 text-[#22C55E]" />}
                    {answered && selectedOptions.includes(idx) && !correctOptions.includes(idx) && <XCircle className="w-5 h-5 text-[#EF4444]" />}
                  </button>
                );
              })}
            </div>
          )}

          {/* Explanation */}
          {answered && result && (
            <div className={`mt-6 p-4 rounded-xl border-l-4 ${
              result.is_correct ? 'bg-[#F0FDF4] border-[#22C55E]' : 'bg-[#FEF2F2] border-[#EF4444]'
            }`} data-testid="explanation-box">
              <div className="flex items-center gap-2 mb-2">
                {result.is_correct ? (
                  <CheckCircle className="w-5 h-5 text-[#22C55E]" />
                ) : (
                  <XCircle className="w-5 h-5 text-[#EF4444]" />
                )}
                <span className={`font-bold ${result.is_correct ? 'text-[#16A34A]' : 'text-[#DC2626]'}`}>
                  {result.is_correct ? 'Bonne réponse !' : 'Mauvaise réponse'}
                </span>
              </div>
              {result.is_dp ? (
                <div className="space-y-4">
                  <p className="text-sm font-semibold text-[#334155]">
                    Score du DP : {result.dp_score} / {result.dp_total}
                  </p>
                  {result.dp_results?.map((r, i) => (
                    <div key={i} className="p-3 bg-white/70 rounded-lg border border-[#E2E8F0]">
                      <p className="font-semibold text-sm text-[#1E293B] mb-1">
                        Sous-question {i + 1} : {r.is_correct ? '✅ Correct' : '❌ Incorrect'}
                      </p>
                      <p className="text-sm text-[#334155] mb-1">{r.question}</p>

                      {(dpSubQuestions[i]?.options || []).length > 0 && (
                        <div className="mt-3 space-y-2">
                          {(dpSubQuestions[i]?.options || []).map((opt, optIdx) => {
                            const isSelected = r.selected_options?.includes(optIdx);
                            const isCorrect = r.correct_options?.includes(optIdx);

                            let optClass = 'border-[#E2E8F0] bg-white';
                            if (isCorrect) optClass = 'border-[#22C55E] bg-[#F0FDF4]';
                            if (isSelected && !isCorrect) optClass = 'border-[#EF4444] bg-[#FEF2F2]';

                            return (
                              <div key={optIdx} className={`p-3 rounded-lg border text-sm ${optClass}`}>
                                <div className="flex items-start gap-3">
                                  <span className="w-7 h-7 rounded-full bg-[#F1F5F9] text-[#64748B] flex items-center justify-center font-bold shrink-0">
                                    {String.fromCharCode(65 + optIdx)}
                                  </span>
                                  <div className="flex-1">
                                    <p className="text-[#1E293B]">{opt.text}</p>
                                    <div className="flex gap-2 mt-1 flex-wrap">
                                      {isSelected && (
                                        <span className="text-xs font-semibold text-[#4F46E5]">
                                          Votre réponse
                                        </span>
                                      )}
                                      {isCorrect && (
                                        <span className="text-xs font-semibold text-[#16A34A]">
                                          Bonne réponse
                                        </span>
                                      )}
                                    </div>
                                  </div>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      )}

                      {r.explanation && (
                        <p className="text-sm text-[#64748B] whitespace-pre-line">{r.explanation}</p>
                      )}
                    </div>
                  ))}
                </div>
              ) : (
                <p className="text-sm text-[#334155] whitespace-pre-line">{result.explanation}</p>
              )}
              {question.course_id && (
                <div className="mt-4 space-y-3">
                  <button
                    type="button"
                    onClick={handleShowCourseExcerpt}
                    disabled={courseExcerptLoading}
                    className="inline-flex items-center gap-2 text-sm font-semibold text-[#4F46E5] hover:text-[#4338CA] disabled:opacity-60"
                    data-testid="view-course-excerpt-btn"
                  >
                    <BookOpen className="w-4 h-4" />
                    {courseExcerptLoading
                      ? 'Recherche du passage...'
                      : courseExcerptOpen
                        ? 'Masquer le passage du cours'
                        : 'Voir le passage du cours'}
                  </button>

                  {courseExcerptOpen && courseExcerpt && (
                    <div className="p-4 bg-white/80 border border-[#E2E8F0] rounded-xl shadow-sm">
                      <div className="flex items-center justify-between gap-3 mb-2">
                        <p className="text-sm font-bold text-[#1E293B]">
                          {courseExcerpt.title}
                        </p>
                        <Link
                          to={`/courses/${question.course_id}`}
                          className="text-xs font-medium text-[#64748B] hover:text-[#4F46E5]"
                        >
                          Ouvrir le cours complet
                        </Link>
                      </div>

                      <div
                        className="text-sm leading-relaxed text-[#334155] max-h-72 overflow-auto pr-2"
                        dangerouslySetInnerHTML={{ __html: courseExcerpt.html }}
                      />
                    </div>
                  )}
                </div>
              )}
            </div>
          )}

          {/* Actions */}
          <div className="flex justify-end mt-6">
            {!answered ? (
              <button
                onClick={submitAnswer}
                disabled={(isQroc ? !qrocText.trim() : selectedOptions.length === 0) || answering}
                className="flex items-center gap-2 bg-[#1E293B] text-white px-6 py-3 rounded-xl font-medium hover:bg-[#0F172A] transition-colors disabled:opacity-50"
                data-testid="submit-answer-btn"
              >
                {answering ? (
                  <div className="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin" />
                ) : (
                  <>
                    {isDp
                      ? (dpStep < dpSubQuestions.length - 1 ? 'Valider et passer à la suite' : 'Terminer le DP')
                      : 'Valider'}
                    <CheckCircle className="w-5 h-5" />
                  </>
                )}
              </button>
            ) : (
              <button
                onClick={nextQuestion}
                className="flex items-center gap-2 bg-gradient-to-r from-[#4F46E5] to-[#7C3AED] text-white px-6 py-3 rounded-xl font-medium hover:opacity-90 transition-opacity"
                data-testid="next-question-btn"
              >
                {currentIndex < session.questions.length - 1 ? 'Suivant' : 'Terminer'}
                <ArrowRight className="w-5 h-5" />
              </button>
            )}
          </div>
        </div>
      </div>
    );
  }

  // ============= QUIZ SETUP =============
  return (
    <div className="max-w-2xl mx-auto space-y-6" data-testid="quiz-setup">
      <div>
        <h1 className="text-4xl font-bold text-[#1E293B]" style={{ fontFamily: 'Outfit, sans-serif' }}>
          Quiz
        </h1>
        <p className="text-[#64748B] mt-2 text-lg">
          Testez vos connaissances et progressez
        </p>
      </div>

      <div className="bg-white rounded-2xl border border-[#E2E8F0] p-6 shadow-sm space-y-6">
        {/* Mode */}
        <div>
          <label className="block text-sm font-semibold text-[#334155] mb-3">Mode de quiz</label>
          <div className="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {Object.entries(MODE_META).map(([value, meta]) => {
              const Icon = meta.icon;
              return (
                <button
                  key={value}
                  onClick={() => setMode(value)}
                  className={`p-3 border-2 rounded-xl text-sm font-medium transition-colors flex items-center gap-2 ${
                    mode === value
                      ? 'border-[#4F46E5] bg-[#EFF6FF] text-[#4F46E5]'
                      : 'border-[#E2E8F0] hover:bg-[#F8FAFC]'
                  }`}
                  data-testid={`mode-${value}`}
                >
                  <Icon className="w-4 h-4" />
                  {meta.label}
                </button>
              );
            })}
          </div>
        </div>

        {/* Subject */}
        {mode === 'subject' && (
          <div>
            <label className="block text-sm font-semibold text-[#334155] mb-2">Matière</label>
            <select
              value={selectedSubject}
              onChange={(e) => setSelectedSubject(e.target.value)}
              className="w-full px-4 py-3 border-2 border-[#E2E8F0] rounded-xl focus:border-[#4F46E5] outline-none bg-white"
              data-testid="subject-select"
            >
              <option value="">Toutes les matières</option>
              {subjects.map(s => <option key={s.id} value={s.id}>{s.name}</option>)}
            </select>
          </div>
        )}

        {/* Course */}
        {mode === 'course' && (
          <div>
            <label className="block text-sm font-semibold text-[#334155] mb-2">Cours</label>
            <select
              value={selectedCourse}
              onChange={(e) => setSelectedCourse(e.target.value)}
              className="w-full px-4 py-3 border-2 border-[#E2E8F0] rounded-xl focus:border-[#4F46E5] outline-none bg-white"
              data-testid="course-select"
            >
              <option value="">Sélectionner un cours</option>
              {courses.map(c => <option key={c.id} value={c.id}>{c.title}</option>)}
            </select>
          </div>
        )}

        {/* Count */}
        <div>
          <label className="block text-sm font-semibold text-[#334155] mb-2">
            Nombre de questions : <span className="text-[#4F46E5]">{questionCount}</span>
          </label>
          <input
            type="range"
            min="5"
            max="30"
            value={questionCount}
            onChange={(e) => setQuestionCount(parseInt(e.target.value))}
            className="w-full"
            data-testid="question-count-slider"
          />
        </div>

        {/* Types */}
        <div>
          <label className="block text-sm font-semibold text-[#334155] mb-3">Types de questions</label>
          <div className="flex flex-wrap gap-2">
            {[
              { value: 'qi', label: 'QI' },
              { value: 'qrm', label: 'QRM' },
              { value: 'qroc', label: 'QROC' },
              { value: 'dp', label: 'Dossier progressif' },
              { value: 'qcm', label: 'QCM (legacy)' },
              { value: 'vrai_faux', label: 'Vrai/Faux (legacy)' },
              { value: 'cas_clinique', label: 'Cas clinique (legacy)' }
            ].map(({ value, label }) => (
              <button
                key={value}
                onClick={() => toggleQuestionType(value)}
                className={`px-4 py-2 rounded-xl text-sm font-semibold transition-colors ${
                  questionTypes.includes(value)
                    ? 'bg-[#1E293B] text-white'
                    : 'bg-[#F1F5F9] text-[#64748B] hover:bg-[#E2E8F0]'
                }`}
                data-testid={`type-${value}`}
              >
                {label}
              </button>
            ))}
          </div>
        </div>

        <button
          onClick={() => startQuiz()}
          disabled={(mode === 'course' && !selectedCourse)}
          className="w-full flex items-center justify-center gap-2 bg-gradient-to-r from-[#4F46E5] to-[#7C3AED] text-white py-4 rounded-xl font-bold text-lg hover:opacity-90 transition-opacity disabled:opacity-50 shadow-lg"
          data-testid="start-quiz-btn"
        >
          <Play className="w-6 h-6" />
          Commencer le quiz
        </button>
      </div>
    </div>
  );
}
