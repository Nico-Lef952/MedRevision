GROUPS = {
    "recall": ["qi", "qrm", "qcm", "vrai_faux"],
    "qroc": ["qroc"],
    "clinical": ["cas_clinique"],
    "dp": ["dp"],
}


def load_env():
    env_path = Path(".env")
    if not env_path.exists():
        return

    for line in env_path.read_text(encoding="utf-8", errors="ignore").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        os.environ.setdefault(key.strip(), value.strip())


def count_words(text):
    text = text or ""
    return len(re.findall(r"\b[\w'-]+\b", text))


def target_profile(word_count):
    # Targets = number of questions/cases per course.
    # DP means number of DP cases, not subquestions.
    if word_count < 900:
        return {
            "recall": 22,
            "qroc": 8,
            "clinical": 10,
            "dp": 4,
        }

    if word_count < 2200:
        return {
            "recall": 38,
            "qroc": 15,
            "clinical": 18,
            "dp": 7,
        }

    if word_count < 4000:
        return {
            "recall": 55,
            "qroc": 25,
            "clinical": 30,
            "dp": 10,
        }

    return {
        "recall": 75,
        "qroc": 35,
        "clinical": 45,
        "dp": 14,
    }


def batch_size_for_group(group):
    if group == "dp":
        return 3
    if group == "clinical":
        return 6
    if group == "qroc":
        return 10
    return 12


def question_group(qtype):
    for group, types in GROUPS.items():
        if qtype in types:
            return group
    return "recall"


def extract_json(text):
    text = text or ""
    text = text.strip()

    if text.startswith("```"):
        text = re.sub(r"^```json", "", text, flags=re.I).strip()
        text = re.sub(r"^```", "", text).strip()
        text = re.sub(r"```$", "", text).strip()

    start = text.find("{")
    end = text.rfind("}")

    if start == -1 or end == -1:
        raise ValueError("No JSON object found")

    return json.loads(text[start:end + 1])


def norm(text):
    return re.sub(r"\s+", " ", (text or "").strip().lower())


def sleep_msg(seconds, reason):
    print("")
    print(f"Pause {round(seconds / 60, 1)} min - {reason}")
    print("")
    time.sleep(seconds)


async def get_user():
    user = await db.users.find_one({"email": "admin@medrevision.com"})
    if not user:
        raise RuntimeError("Admin user not found")
    return user


async def get_subject(subject_id):
    if not subject_id:
        return None
    try:
        return await db.subjects.find_one({"_id": ObjectId(subject_id)})
    except Exception:
        return None


async def get_course_stats(user_id, course):
    course_id = str(course["_id"])
    questions = await db.questions.find({
        "user_id": user_id,
        "course_id": course_id
    }).to_list(5000)

    counts = {
        "recall": 0,
        "qroc": 0,
        "clinical": 0,
        "dp": 0,
    }

    existing_titles = []

    for q in questions:
        g = question_group(q.get("type", ""))
        counts[g] += 1
        existing_titles.append({
            "id": str(q["_id"]),
            "type": q.get("type", ""),
            "question": q.get("question", ""),
            "concepts": q.get("concepts", []),
        })

    word_count = count_words(course.get("content", "") or "")
    targets = target_profile(word_count)

    deficits = {}
    for group in counts:
        deficits[group] = max(0, targets[group] - counts[group])

    total_current = sum(counts.values())
    total_target = sum(targets.values())

    return {
        "questions": questions,
        "existing_titles": existing_titles,
        "counts": counts,
        "targets": targets,
        "deficits": deficits,
        "word_count": word_count,
        "total_current": total_current,
        "total_target": total_target,
    }


def choose_generation_task(stats):
    best_group = None
    best_ratio = 0

    for group, deficit in stats["deficits"].items():
        target = max(1, stats["targets"][group])
        ratio = deficit / target

        if deficit > 0 and ratio > best_ratio:
            best_ratio = ratio
            best_group = group

    return best_group


